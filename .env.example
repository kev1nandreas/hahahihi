# Salin file ini menjadi `.env` lalu isi nilainya.
# Generate kunci baru: python -c "import secrets; print(secrets.token_hex(32))"
NRP_SECRET_KEY=isi-dengan-kunci-acak-256-bit
PBKDF2_ITERATIONS=200000
# Daftar NRP diterima, pisah koma. NRP lain otomatis = ditolak.
NRP_DITERIMA=5025240001,5025240002
