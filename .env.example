# Salin file ini menjadi `.env` lalu isi nilainya.
# Generate kunci baru: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NRP_SECRET_KEY=isi-dengan-kunci-acak-256-bit
PBKDF2_ITERATIONS=200000
# Daftar NRP diterima, pisah koma. NRP lain otomatis = ditolak.
NRP_DITERIMA=5025240001,5025240002

# Kata kunci jawaban TF-IDF (pisah koma). Dipakai HANYA oleh
# generate_datasets.py saat membuat corpus_*.txt — bukan env Vercel.
# Setelah ganti: jalankan `python generate_datasets.py` untuk regenerate corpus.
KEYWORD_DITERIMA=selamat,diterima,lolos,berhasil,bergabung
KEYWORD_DITOLAK=semangat,ditolak,belum,coba,lagi
